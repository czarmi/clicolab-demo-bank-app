NODE_ENV=development
PORT=4000

# PostgreSQL
PG_HOST=postgres
PG_PORT=5432
PG_USER=clicolab
PG_PASSWORD=clicolab_secret
PG_DATABASE=clicolab_demo_bank

# Redis (sessions / token blacklist)
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h
SESSION_SECRET=change_me_session_secret

# SAML (Identity Provider) - example values, replace with real IdP config (e.g. Azure AD, Okta, Keycloak)
SAML_ENTRY_POINT=https://idp.example.com/sso/saml
SAML_ISSUER=clicolab-demo-bank-app
SAML_CALLBACK_URL=http://localhost/api/auth/saml/callback
SAML_CERT_PATH=./src/config/idp-cert.pem

FRONTEND_URL=http://localhost
